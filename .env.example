# Bandsintown app id used by the Shows page (server-side)
BANDSINTOWN_APP_ID=

# Formspree form id for the Contact form (exposed to the browser)
NEXT_PUBLIC_FORMSPREE_ID=

# Canonical site URL for absolute OG / metadata links, e.g. https://cleantonesband.com
NEXT_PUBLIC_SITE_URL=

# YouTube Data API v3 — powers the /scroll reels feed (server-side, kept secret).
# Get a key at https://console.cloud.google.com (enable "YouTube Data API v3").
YOUTUBE_API_KEY=
# Either the channel id (UC…) to auto-pull Shorts-length uploads…
YOUTUBE_CHANNEL_ID=
# …or a curated Shorts playlist id (PL…) for exact control (takes priority).
YOUTUBE_SHORTS_PLAYLIST_ID=
